# Copy this to .env and fill in your values

# Supabase PostgreSQL connection string
# Get this from: Supabase Dashboard → Project → Settings → Database → Connection String → Transaction (port 6543)
# Add ?pgbouncer=true at the end for transaction pooler
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:6543/postgres?pgbouncer=true
