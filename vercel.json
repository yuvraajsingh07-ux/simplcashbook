{
  "version": 2,
  "buildCommand": "cd artifacts/cashbook && pnpm install && pnpm run build",
  "outputDirectory": "artifacts/cashbook/dist",
  "installCommand": "pnpm install",
  "framework": null,
  "functions": {
    "artifacts/cashbook/api/**/*.ts": {
      "runtime": "@vercel/node"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/artifacts/cashbook/api/$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
